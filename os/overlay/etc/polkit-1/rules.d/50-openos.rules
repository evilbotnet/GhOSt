// OpenOS: allow the kiosk user to manage networking (and later, updates)
// without sudo. Scoped per-action, auditable, no root daemon anywhere.
polkit.addRule(function (action, subject) {
  if (subject.user !== "openos") return polkit.Result.NOT_HANDLED;

  if (action.id.indexOf("org.freedesktop.NetworkManager.") === 0) {
    return polkit.Result.YES;
  }
  // Phase 5: org.freedesktop.packagekit.system-update for the Updates panel.
  return polkit.Result.NOT_HANDLED;
});
