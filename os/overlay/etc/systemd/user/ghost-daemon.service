[Unit]
Description=GhOSt system daemon (ghostd)
# Globally enabled, but only the kiosk user should run it (not ssh logins).
ConditionUser=ghost

[Service]
Environment=GHOST_OFFICE_URL=http://localhost:3000
ExecStart=/usr/local/bin/ghostd --listen 127.0.0.1:7700 --token-file %h/.config/ghost/token --static /usr/share/ghost/shell
Restart=always
RestartSec=1
# ghostd must never run as root; privileged actions go through NM/logind/polkit.
NoNewPrivileges=yes

[Install]
WantedBy=default.target
