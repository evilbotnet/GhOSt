#!/usr/bin/env bash
# ghost-install-devkit — install terminal AI coding agents (pi, herdr) and wire
# them to GhOSt's model gateway (ADR 0003). Runs as the *ghost user* — no root:
# packages go to a user prefix and wrappers to ~/.local/bin, which is on PATH.
#
# The wrappers point the tools at http://127.0.0.1:7700/v1 with the GhOSt
# session token as the API key, so pi/herdr inherit your configured model,
# routing, and keys with zero setup — and all their traffic is auditable through
# ghostd's gateway. Triggered one-click from OOBE / Settings via the daemon.
#
# Package names are overridable so they can be corrected without editing logic.
set -euo pipefail

PI_PKG="${GHOST_PI_PKG:-@earendil-works/pi-coding-agent}"
HERDR_PKG="${GHOST_HERDR_PKG:-herdr}"
PREFIX="$HOME/.local"
BIN="$PREFIX/bin"
STATE="$HOME/.config/ghost/devkit.state"

mkdir -p "$HOME/.config/ghost" "$BIN" "$PREFIX/lib"
echo "installing" > "$STATE"
fail() { echo "failed: $*" > "$STATE"; echo "devkit: $*" >&2; exit 1; }

command -v node >/dev/null 2>&1 || fail "Node.js not found — install the Office suite first (it brings Node), or 'sudo apt install nodejs npm'"
command -v npm  >/dev/null 2>&1 || fail "npm not found"

# A gateway wrapper: real tool, but pointed at ghostd's /v1 with the live token.
write_wrapper() {
  local name="$1" target="$2"
  cat > "$BIN/$name" <<EOF
#!/usr/bin/env bash
# Auto-generated by ghost-install-devkit — $name via GhOSt's model gateway.
export OPENAI_BASE_URL="http://127.0.0.1:7700/v1"
export OPENAI_API_KEY="\$(cat "\$HOME/.config/ghost/token" 2>/dev/null)"
exec "$target" "\$@"
EOF
  chmod +x "$BIN/$name"
}

echo "==> installing pi ($PI_PKG)"
npm install --prefix "$PREFIX" "$PI_PKG" --no-audit --no-fund >/dev/null 2>&1 \
  || fail "npm install $PI_PKG failed"
PI_BIN="$(ls "$PREFIX"/lib/node_modules/.bin/pi 2>/dev/null || echo "$BIN/.pi-real")"
# npm --prefix puts bins in $PREFIX/bin; move the real one aside so our wrapper wins.
if [[ -x "$BIN/pi" && ! -f "$BIN/.pi-real" ]]; then mv "$BIN/pi" "$BIN/.pi-real"; fi
write_wrapper pi "$BIN/.pi-real"

echo "==> installing herdr ($HERDR_PKG) — optional"
if npm install --prefix "$PREFIX" "$HERDR_PKG" --no-audit --no-fund >/dev/null 2>&1; then
  if [[ -x "$BIN/herdr" && ! -f "$BIN/.herdr-real" ]]; then mv "$BIN/herdr" "$BIN/.herdr-real"; fi
  write_wrapper herdr "$BIN/.herdr-real"
else
  echo "devkit: herdr install skipped (package '$HERDR_PKG' unavailable) — pi installed" >&2
fi

echo "ok" > "$STATE"
echo "==> devkit ready — run 'pi' (and 'herdr' if installed) in a Terminal"
